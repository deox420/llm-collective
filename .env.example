# ============================================================
# LLM Collective — configuración de entorno
# Copia este archivo a .env y rellena lo que necesites.
# ============================================================

# --- PERFIL DE MODELOS -------------------------------------
# Decide DÓNDE corre cada modelo sin tocar código (ver shared/model_config.py).
#   cloud_only      -> TODO en Ollama Cloud. Empieza aquí: solo necesitas tu
#                      suscripción de Ollama Cloud. Construye y prueba sin GPU.
#   local_dev       -> modelos 7-8B en tu equipo (RTX). Gratis para trastear.
#   cloud_plus_gpu  -> chairman/architect en GPU (física o alquilada) + resto cloud.
#                      Cambia a este perfil CUANDO DECIDAS físico vs alquiler.
MODEL_PROFILE=cloud_only

# --- Ollama Cloud (NECESARIO para empezar con cloud_only) --
# Plan Pro recomendado: 3 modelos concurrentes.
OLLAMA_CLOUD_HOST=https://ollama.com
OLLAMA_CLOUD_API_KEY=

# --- GPU alquilada o física corriendo Ollama --------------
# DÉJALO VACÍO de momento. Lo rellenas cuando decidas:
#   - Alquiler (Runpod/Vast/Spheron): pon aquí el host del pod (solo por túnel).
#   - GPU física en tu equipo: usa el perfil local_dev / prefijo local/ en su lugar.
GPU_HOST=

# --- Ollama local (opcional, para local_dev) --------------
OLLAMA_LOCAL_HOST=http://localhost:11434

# --- Anthropic API (opcional, de pago) --------------------
ANTHROPIC_API_KEY=

# --- PixelLab (pixel-art, solo a partir de la Fase 6) -----
# NO subir la clave real al repo. Ver ASSETS.md.
PIXELLAB_API_KEY=

# --- Second Brain -----------------------------------------
# Ruta a tu vault de Obsidian (Fase 5). Déjalo vacío hasta entonces.
OBSIDIAN_VAULT_PATH=
